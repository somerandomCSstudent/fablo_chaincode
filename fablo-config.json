{
  "$schema": "https://github.com/hyperledger-labs/fablo/releases/download/2.5.0/schema.json",
  "global": {
    "fabricVersion": "3.1.0",
    "tls": true,
    "peerDevMode": false,
    "engine": "docker"
  },
  "orgs": [
    {
      "organization": {
        "name": "Orderer",
        "domain": "orderer.example.com",
        "mspName": "OrdererMSP"
      },
      "ca": {
        "prefix": "ca",
        "db": "sqlite"
      },
      "orderers": [
        {
          "groupName": "group1",
          "type": "BFT",
          "instances": 2,
          "prefix": "orderer"
        }
      ],
      "tools": {
        "fabloRest": true
      }
    },
    {
      "organization": {
        "name": "Org1",
        "domain": "org1.example.com",
        "mspName": "Org1MSP"
      },
      "ca": {
        "prefix": "ca",
        "db": "sqlite"
      },
      "orderers": [],
      "peer": {
        "instances": 1,
        "db": "LevelDb",
        "prefix": "peer"
      },
      "tools": {
        "fabloRest": true
      }
    }
  ],
  "channels": [
    {
      "name": "my-channel1",
      "orgs": [
        {
          "name": "Org1",
          "peers": [
            "peer0"
          ]
        }
      ]
    }
  ],
  "chaincodes": [
    {
      "name": "chaincode1",
      "version": "0.0.1",
      "channel": "my-channel1",
      "lang": "java",
      "directory": "./chaincodes/kuczo_chaincodes",
      "privateData": []
    }
  ],
  "hooks": {}
}